# Configuration MongoDB
# Copier ce fichier en .env et remplir avec les vraies valeurs
# NEVER COMMIT .env !

# MongoDB Local (Docker)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=TON_MOT_DE_PASSE_ROOT
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=migrate_user
MONGO_PASSWORD=TON_MOT_DE_PASSE_MIGRATE
MONGO_READONLY_PASSWORD=TON_MOT_DE_PASSE_READONLY
MONGO_DB=healthcare

# MongoDB Atlas (Cloud)
MONGO_ATLAS_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/?appName=APPNAME

# Chemins
CSV_PATH=data/healthcare_dataset.csv
